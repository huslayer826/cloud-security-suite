# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored and should not be committed.

aws_region          = "us-east-1"
project_name        = "cloud-security-suite"
environment         = "prod"
notification_email  = "you@example.com"
schedule_expression = "rate(24 hours)"

# GuardDuty Processor
enable_guardduty          = false
guardduty_auto_remediate  = false
guardduty_dry_run         = true
slack_webhook_url         = ""
